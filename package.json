{
  "name": "memaxx-memory",
  "version": "3.0.0",
  "description": "MEMAXX Memory — Self-hosted AI memory for coding assistants. Docker-ready, HTTP + MCP server.",
  "type": "module",
  "scripts": {
    "start": "node bin.mjs",
    "dev": "node --watch bin.mjs",
    "stdio": "node bin.mjs --stdio",
    "setup": "node bin.mjs --setup",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "sqlite-vec": "^0.1.0"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "cursor",
    "claude",
    "model-context-protocol",
    "memaxx",
    "self-hosted",
    "local",
    "sqlite",
    "ollama"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "javascript-obfuscator": "^5.3.0"
  }
}
