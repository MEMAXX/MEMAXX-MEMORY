{
  "name": "memaxx-memory",
  "version": "4.0.0",
  "description": "MEMAXX Memory — Self-hosted AI memory for coding assistants. PostgreSQL + pgvector, Docker-ready.",
  "type": "module",
  "scripts": {
    "start": "node bin.mjs",
    "dev": "node --watch bin.mjs",
    "stdio": "node bin.mjs --stdio",
    "setup": "node bin.mjs --setup",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "restore": "node scripts/restore.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "postinstall": "bash scripts/install-hooks.sh || true"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.19.0"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "cursor",
    "claude",
    "model-context-protocol",
    "memaxx",
    "self-hosted",
    "postgresql",
    "pgvector",
    "docker",
    "ollama"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "javascript-obfuscator": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
