{
  "name": "memaxx-memory",
  "version": "4.0.0",
  "description": "MEMAXX Memory — Self-hosted AI memory for coding assistants. PostgreSQL + pgvector, Docker-ready.",
  "type": "module",
  "scripts": {
    "start": "node bin.mjs",
    "dev": "node --watch bin.mjs",
    "stdio": "node bin.mjs --stdio",
    "setup": "node bin.mjs --setup",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "cursor",
    "claude",
    "model-context-protocol",
    "memaxx",
    "self-hosted",
    "postgresql",
    "pgvector",
    "docker",
    "ollama"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
