# MEMAXX Memory — Environment Configuration
# Copy to .env: cp .env.example .env

# ── PostgreSQL Password ──────────────────────────────────────────────
POSTGRES_PASSWORD=memaxx

# ── Required: Embedding Provider ─────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small

# ── Optional: LLM for Entity Extraction (Knowledge Graph) ───────────
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# ── Optional: Auth Token for Remote Access ───────────────────────────
# AUTH_TOKEN=your-secret-token

# ── Optional: Custom Port ────────────────────────────────────────────
# PORT=3100

# ── Ollama (100% local, no API key) ─────────────────────────────────
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_BASE_URL=http://host.docker.internal:11434
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://host.docker.internal:11434
