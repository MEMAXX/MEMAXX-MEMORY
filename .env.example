# MEMAXX Memory — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Required: Embedding Provider ─────────────────────────────────────
# Choose one: openai, openrouter, ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small

# ── Optional: LLM for Entity Extraction (Knowledge Graph) ───────────
# If not set, knowledge graph extraction is disabled
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# ── Optional: Auth Token for Remote Access ───────────────────────────
# Set this if accessing MEMAXX over the network (e.g., via Tailscale)
# Clients must send: Authorization: Bearer <token>
# AUTH_TOKEN=your-secret-token

# ── Ollama Example ───────────────────────────────────────────────────
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_BASE_URL=http://host.docker.internal:11434
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://host.docker.internal:11434
# LLM_MODEL=llama3.2
