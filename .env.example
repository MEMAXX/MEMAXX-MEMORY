# MEMAXX Memory — Environment Configuration
# Copy to .env and add your API key: cp .env.example .env

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=memaxx

# ── Embedding Provider (for semantic search) ─────────────────────────
# Choose: openai, openrouter, or ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small

# ── LLM Provider (for knowledge graph entity extraction) ─────────────
# Uses same provider/key as embedding by default
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# ── Auth Token (set this for remote access via Tailscale/VPN) ────────
# AUTH_TOKEN=your-secret-token

# ────────────────────────────────────────────────────────────────────
# ALTERNATIVE: OpenRouter (pay-per-use, no subscription)
# ────────────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER=openrouter
# EMBEDDING_API_KEY=sk-or-your-key-here
# EMBEDDING_MODEL=openai/text-embedding-3-small
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-your-key-here
# LLM_MODEL=anthropic/claude-3.5-haiku

# ────────────────────────────────────────────────────────────────────
# ALTERNATIVE: Ollama (100% local, free, no API key)
# ────────────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_BASE_URL=http://host.docker.internal:11434
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://host.docker.internal:11434
